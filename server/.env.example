# Backend environment variables
# Copy to `server/.env` for local development (do NOT commit .env)

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Used to sign/verify JWTs (required)
JWT_SECRET=replace-with-a-long-random-secret

# Recommended (production): comma-separated list of allowed origins
# Supports wildcard entries, e.g. https://*.vercel.app
# Example: https://your-web-domain.com,https://*.vercel.app,http://localhost:5173
CORS_ORIGINS=

# Optional explicit frontend origin for platform deployments
# Example: https://barbershop-graph.vercel.app
FRONTEND_URL=

# Optional explicit reset-page base URL (defaults to FRONTEND_URL)
# Example: https://barbershop-graph.vercel.app
RESET_PASSWORD_BASE_URL=

# SMTP settings for real password reset emails
# Example for Gmail/Google Workspace: host=smtp.gmail.com, port=587, secure=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Salonify <no-reply@your-domain.com>"

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# These are free, self-hosted keys. No third-party service needed.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@barbershop.app

# Optional
PORT=3000
NODE_ENV=development

